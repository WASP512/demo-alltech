---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout
  title="About AllTech"
  description="AllTech is a Hyde Park, UT-based IT and cybersecurity firm serving Northern Utah, the Wasatch Front, and southern Idaho since 2009."
>
  <section class="surface-dark bg-motif relative overflow-hidden">
    <div class="glow-amber" style="top: -200px; right: -100px;"></div>
    <div class="relative container-wide py-16 lg:py-20">
      <div class="eyebrow mb-4">About</div>
      <h1 class="font-display text-5xl lg:text-6xl font-semibold leading-tight max-w-3xl">
        Built for the businesses<br/>that <span style="color: var(--color-amber-400);">build Northern Utah</span>.
      </h1>
    </div>
  </section>

  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-prose">
      <div class="eyebrow mb-4">Who we are today</div>
      <div class="space-y-6 text-lg leading-relaxed text-muted">
        <p>
          AllTech is a Northern Utah team of engineers who design, deploy, and run
          technology for small and mid-sized businesses. We're a security-led managed
          IT provider — not a one-person help desk, and not a faceless national NOC.
        </p>
        <p>
          Local since 2009, we run real infrastructure for manufacturing operations,
          schools, title companies, and multi-site businesses across the Wasatch Front
          and southern Idaho. When you call, you reach the same people who designed
          your network.
        </p>
        <p>
          Our approach is simple: <strong style="color: var(--color-text-primary);">proactive,
          preventative, professional</strong>. We bring enterprise tooling — Cloudflare,
          Ubiquiti UniFi, Datto, and Microsoft 365 — down to where mid-market businesses
          can actually use it, and we stand behind it.
        </p>
      </div>

      <div class="hairline my-10"></div>

      <div class="eyebrow mb-5">What we do today</div>
      <div class="grid sm:grid-cols-2 gap-x-8 gap-y-3 not-prose mb-2">
        {[
          'Managed IT & help desk',
          'Cybersecurity & the AllTech Top 10',
          'SASE / Zero Trust (Powered by Cloudflare)',
          'Networks, cameras & low-voltage install',
          'Microsoft 365 & cloud',
          'Utah data recovery',
        ].map((item) => (
          <div class="flex items-start gap-2.5">
            <svg class="w-5 h-5 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 10.5l3.5 3.5L16 6" stroke="var(--color-amber-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span style="color: var(--color-text-default)">{item}</span>
          </div>
        ))}
      </div>

      <div class="hairline my-10"></div>

      <div class="grid sm:grid-cols-3 gap-6 not-prose">
        <div>
          <div class="font-display text-3xl font-semibold" style="color: var(--color-amber-400);">2009</div>
          <div class="text-sm text-subtle mt-1">Local since</div>
        </div>
        <div>
          <div class="font-display text-3xl font-semibold" style="color: var(--color-amber-400);">Cloudflare</div>
          <div class="text-sm text-subtle mt-1">Official Partner</div>
        </div>
        <div>
          <div class="font-display text-3xl font-semibold" style="color: var(--color-amber-400);">In-house</div>
          <div class="text-sm text-subtle mt-1">No outsourced help desk</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
