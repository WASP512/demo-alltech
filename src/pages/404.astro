---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="We couldn't find that page." noindex>
  <section class="py-32">
    <div class="container-prose text-center">
      <div class="font-mono text-accent-500 text-sm tracking-widest">404 · NOT FOUND</div>
      <h1 class="mt-4 font-display text-5xl lg:text-6xl font-semibold">That page is offline.</h1>
      <p class="mt-5 text-lg text-ink-600">
        It may have moved, or you may have typed the address slightly wrong.
        Try one of these:
      </p>
      <div class="mt-8 flex justify-center gap-3 flex-wrap">
        <a href="/" class="btn btn-primary">Home</a>
        <a href="/services" class="btn btn-ghost">Services</a>
        <a href="/contact" class="btn btn-ghost">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
