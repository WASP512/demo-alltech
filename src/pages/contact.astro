---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ContactForm from '~/components/ContactForm';
import { site } from '~/lib/site';

const defaultService = Astro.url.searchParams.get('service') ?? undefined;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<BaseLayout
  title="Contact AllTech"
  description="Reach AllTech for managed IT, cybersecurity, or Cloudflare deployments. Based in Hyde Park, UT — serving Northern Utah, Box Elder County, and southern Idaho."
>
  {turnstileSiteKey && (
    <script slot="head" src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer is:inline />
  )}

  <section class="surface-dark relative overflow-hidden">
    <div class="glow-amber" style="top: -200px; right: -100px;"></div>
    <div class="relative container-wide py-16 lg:py-20">
      <div class="eyebrow mb-4">Contact</div>
      <h1 class="font-display text-5xl lg:text-6xl font-semibold leading-tight max-w-3xl">
        Tell us what you're <span style="color: var(--color-amber-400);">working on</span>.
      </h1>
      <p class="mt-5 text-xl max-w-2xl leading-relaxed text-muted">
        A real person reads every message and connects you with the right expert on our team.
      </p>
    </div>
  </section>

  <section class="surface-dark py-16 lg:py-20">
    <div class="container-wide grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-7">
        <div class="rounded-lg p-8 lg:p-10" style="background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle);">
          <ContactForm
            client:load
            defaultService={defaultService}
            turnstileSiteKey={turnstileSiteKey}
          />
        </div>
      </div>

      <aside class="lg:col-span-5 space-y-8">
        <div>
          <div class="eyebrow mb-3">Direct lines</div>
          <div class="space-y-3 text-lg">
            <div>
              <div class="text-sm text-subtle">Phone</div>
              <a href={`tel:${site.phoneE164}`} class="font-mono font-medium transition-colors" style="color: var(--color-text-primary);"
                 onmouseover="this.style.color='var(--color-amber-300)'"
                 onmouseout="this.style.color='var(--color-text-primary)'">{site.phone}</a>
            </div>
          </div>
        </div>

        <div class="hairline"></div>

        <div>
          <div class="eyebrow mb-3">Office</div>
          <address class="not-italic text-lg leading-relaxed" style="color: var(--color-text-primary);">
            {site.address.street}<br />
            {site.address.city}, {site.address.region} {site.address.postalCode}
          </address>
        </div>

        <div>
          <div class="eyebrow mb-3">Hours</div>
          <p style="color: var(--color-text-primary);">Monday – Friday · 8:00 AM – 5:00 PM</p>
          <p class="text-sm text-subtle mt-1">After-hours emergencies: call the main line.</p>
        </div>

        <div class="rounded-lg overflow-hidden aspect-[4/3]" style="border: 1px solid var(--color-line-soft);">
          <iframe
            title="AllTech office map"
            src="https://maps.google.com/maps?q=Alltech%2C%20Hyde%20Park%2C%20Ut%2C%2084318&t=m&z=14&output=embed&iwloc=near"
            class="w-full h-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          />
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
