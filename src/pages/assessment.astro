---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AssessmentForm from '~/components/AssessmentForm';

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<BaseLayout
  title="Security Gap Assessment"
  description="Take AllTech's free self-serve security gap assessment. Answer a few questions about your backups, patching, firewall, identity, endpoints, and more — get a posture score and tailored next steps from our team."
>
  {turnstileSiteKey && (
    <script slot="head" src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer is:inline />
  )}

  <section class="surface-dark bg-motif relative overflow-hidden">
    <div class="glow-amber" style="top: -200px; right: -100px;"></div>
    <div class="relative container-wide py-16 lg:py-20">
      <div class="eyebrow mb-4">Free Self-Assessment</div>
      <h1 class="font-display text-5xl lg:text-6xl font-semibold leading-tight max-w-3xl">
        Where are your <span style="color: var(--color-amber-400);">security gaps</span>?
      </h1>
      <p class="mt-5 text-xl max-w-2xl leading-relaxed text-muted">
        Answer a few quick questions across 12 security domains. You'll get a posture
        score on the spot — and our team will follow up with tailored next steps.
      </p>
    </div>
  </section>

  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-prose">
      <div class="rounded-lg p-8 lg:p-10" style="background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle);">
        <AssessmentForm client:load turnstileSiteKey={turnstileSiteKey} />
      </div>
    </div>
  </section>
</BaseLayout>
