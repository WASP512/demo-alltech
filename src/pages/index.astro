  /* Speed the sweep up a touch on hover — reads as "engaging". */
  .cta-orbit-wrap:hover .orbit-a { animation-duration: 3.8s; }
  .cta-orbit-wrap:hover .orbit-b { animation-duration: 4.5s; }
