---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { services, site } from '~/lib/site';

const featured = services.find((s) => s.featured);
const rest = services.filter((s) => !s.featured);
---

<BaseLayout
  title="Managed IT, Cybersecurity & Cloudflare Zero Trust"
  description="AllTech is a Cache Valley managed IT and cybersecurity provider. Cloudflare Partner, UniFi specialist, 24/7 monitoring. Serving Logan, Tremonton, Brigham City, Preston, and northern Utah."
>
  <!-- ============ HERO ============ -->
  <section class="relative overflow-hidden">
    <!-- Layered motif backgrounds -->
    <div class="absolute inset-0 bg-dot-grid-fade"></div>
    <div class="absolute inset-0 bg-glow-amber"></div>

    <!-- Decorative topology SVG on the right -->
    <svg
      class="hidden lg:block absolute right-0 top-1/2 -translate-y-1/2 -z-0 opacity-50 pointer-events-none"
      width="560" height="560" viewBox="0 0 560 560" fill="none" aria-hidden="true"
    >
      <!-- Concentric square frames (the AllTech motif — squares not circles, distinct from Cloudflare) -->
      <rect x="60"  y="60"  width="440" height="440" rx="6" stroke="rgba(255,170,51,0.10)" stroke-width="1" stroke-dasharray="2 4" />
      <rect x="110" y="110" width="340" height="340" rx="6" stroke="rgba(255,170,51,0.14)" stroke-width="1" stroke-dasharray="2 4" />
      <rect x="180" y="180" width="200" height="200" rx="6" stroke="rgba(255,170,51,0.18)" stroke-width="1" />

      <!-- Node dots at the intersections -->
      <g fill="rgba(255,170,51,0.6)">
        <circle cx="60"  cy="60"  r="3" />
        <circle cx="500" cy="60"  r="3" />
        <circle cx="60"  cy="500" r="3" />
        <circle cx="500" cy="500" r="3" />
        <circle cx="110" cy="110" r="2" />
        <circle cx="450" cy="110" r="2" />
        <circle cx="110" cy="450" r="2" />
        <circle cx="450" cy="450" r="2" />
        <circle cx="280" cy="280" r="4" fill="rgba(255,170,51,0.9)" />
      </g>

      <!-- Crosshair through center node -->
      <line x1="280" y1="180" x2="280" y2="380" stroke="rgba(255,170,51,0.15)" stroke-width="1" />
      <line x1="180" y1="280" x2="380" y2="280" stroke="rgba(255,170,51,0.15)" stroke-width="1" />
    </svg>

    <div class="relative container-wide pt-24 pb-32 lg:pt-32 lg:pb-40">
      <div class="max-w-3xl">
        <div class="eyebrow mb-5">Managed IT · Cybersecurity · Northern Utah</div>

        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-semibold leading-[0.95] tracking-tight" style="color: var(--color-text-primary)">
          IT that actually <span style="color: var(--color-amber-400)">works</span>,<br />
          security that actually <span style="color: var(--color-amber-400)">holds</span>.
        </h1>

        <p class="mt-7 text-xl max-w-2xl leading-relaxed" style="color: var(--color-text-default)">
          AllTech designs, deploys, and runs the infrastructure that keeps Cache Valley
          businesses online and secure — from UniFi networks to full Cloudflare Zero Trust rollouts.
        </p>

        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">
            Talk to an engineer
            <span aria-hidden="true">→</span>
          </a>
          <a href="/services" class="btn btn-ghost">See what we do</a>
        </div>

        <div class="mt-14 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm" style="color: var(--color-text-muted)">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" style="color: var(--color-amber-400)" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span>5.0 on Google · local since 2009</span>
          </div>
          <div>Cloudflare Partner</div>
          <div>UniFi specialist</div>
          <div>24/7 monitoring</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ VALUE PROPOSITION ============ -->
  <section class="py-24 lg:py-32 border-t" style="border-color: var(--color-border-subtle)">
    <div class="container-wide grid lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-5">
        <div class="eyebrow mb-4">Why AllTech</div>
        <h2 class="text-4xl lg:text-5xl font-semibold leading-tight">
          Most MSPs sell you tickets.<br />
          <span style="color: var(--color-amber-400)">We sell you uptime.</span>
        </h2>
      </div>
      <div class="lg:col-span-7 space-y-6 text-lg leading-relaxed" style="color: var(--color-text-default)">
        <p>
          You don't need another vendor that shows up after the firewall is down.
          You need engineers who designed the firewall in the first place — who know
          your network because they built it, and who can tell you, at 2 a.m. on a
          Tuesday, exactly why a tunnel is flapping.
        </p>
        <p>
          We run real infrastructure for real businesses: manufacturing lines, title
          companies, schools, multi-site operations. We bring enterprise-grade tools —
          Cloudflare Zero Trust, Darktrace, Datto, UniFi — down to where mid-market
          businesses can actually use them.
        </p>
        <div class="hairline"></div>
        <div class="grid grid-cols-3 gap-6 pt-2">
          <div>
            <div class="font-display text-3xl font-semibold" style="color: var(--color-text-primary)">17+</div>
            <div class="text-sm mt-1" style="color: var(--color-text-muted)">Years in Cache Valley</div>
          </div>
          <div>
            <div class="font-display text-3xl font-semibold" style="color: var(--color-text-primary)">14</div>
            <div class="text-sm mt-1" style="color: var(--color-text-muted)">Client organizations</div>
          </div>
          <div>
            <div class="font-display text-3xl font-semibold" style="color: var(--color-text-primary)">24/7</div>
            <div class="text-sm mt-1" style="color: var(--color-text-muted)">Monitoring & response</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="py-24 lg:py-32 border-t" style="border-color: var(--color-border-subtle)">
    <div class="container-wide">
      <div class="max-w-2xl mb-14">
        <div class="eyebrow mb-4">What we do</div>
        <h2 class="text-4xl lg:text-5xl font-semibold leading-tight">
          Six disciplines.<br />One team.
        </h2>
        <p class="mt-5 text-lg leading-relaxed" style="color: var(--color-text-default)">
          Everything below is delivered in-house by engineers who specialize in it —
          not subcontracted to a faceless NOC.
        </p>
      </div>

      <!-- Featured Cloudflare card -->
      {featured && (
        <a
          href={`/services/${featured.slug}`}
          class="card-amber group block mb-5 p-8 lg:p-10 relative overflow-hidden"
        >
          <div class="absolute top-0 right-0 w-80 h-80 rounded-full blur-3xl pointer-events-none" style="background: rgba(255,170,51,0.15)"></div>
          <div class="relative grid lg:grid-cols-12 gap-6 items-center">
            <div class="lg:col-span-8">
              <div class="eyebrow mb-3">Featured · Cloudflare Partner</div>
              <h3 class="font-display text-3xl lg:text-4xl font-semibold mb-3" style="color: var(--color-text-primary)">
                {featured.name}
              </h3>
              <p class="text-lg leading-relaxed max-w-2xl" style="color: var(--color-text-default)">{featured.short}</p>
            </div>
            <div class="lg:col-span-4 lg:text-right">
              <span class="inline-flex items-center gap-2 font-medium text-sm group-hover:gap-3 transition-all" style="color: var(--color-amber-300)">
                Explore Zero Trust
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </div>
        </a>
      )}

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {rest.map((service) => (
          <a href={`/services/${service.slug}`} class="card group block">
            <h3 class="font-display text-xl font-semibold mb-2 group-hover:text-[var(--color-amber-300)] transition" style="color: var(--color-text-primary)">
              {service.name}
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-default)">{service.short}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium" style="color: var(--color-amber-300)">
              Learn more <span aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIAL ============ -->
  <section class="py-24 lg:py-32 border-t" style="border-color: var(--color-border-subtle)">
    <div class="container-prose">
      <div class="eyebrow mb-6">In their words</div>
      <blockquote class="font-display text-3xl lg:text-4xl leading-snug" style="color: var(--color-text-primary)">
        "Very innovative with the latest technology. They care about making sure that
        every client is given the best value in technology. Caring people who hold
        client care as their priority."
      </blockquote>
      <div class="mt-8 text-sm" style="color: var(--color-text-muted)">
        <span class="font-medium" style="color: var(--color-text-primary)">Jamie Forbush</span> · Logan, UT
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="py-24 lg:py-32 border-t" style="border-color: var(--color-border-subtle)">
    <div class="container-wide">
      <div class="card-amber p-10 lg:p-14 grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-8">
          <h2 class="font-display text-3xl lg:text-4xl font-semibold leading-tight">
            Stop fighting with your IT.<br />
            <span style="color: var(--color-amber-400)">Start using it.</span>
          </h2>
          <p class="mt-4 text-lg max-w-2xl" style="color: var(--color-text-default)">
            Tell us what's broken or what you're trying to build. We'll come back
            with a plan — not a sales pitch.
          </p>
        </div>
        <div class="lg:col-span-4 flex flex-wrap gap-3 lg:justify-end">
          <a href="/contact" class="btn btn-primary">Start a conversation</a>
          <a href={`tel:${site.phoneE164}`} class="btn btn-ghost font-mono">{site.phone}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
