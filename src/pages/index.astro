---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SegmentHeader from '~/components/SegmentHeader.astro';
import Icon from '~/components/Icon.astro';
import { services, site, serviceLink } from '~/lib/site';

const featured = services.find((s) => s.featured);
// Second section embeds the Services page (all non-featured services).
const rest = services.filter((s) => !s.featured);
---

<BaseLayout
  title="Managed IT, Cybersecurity & Cloudflare Zero Trust"
  description="AllTech is a Northern Utah managed IT and cybersecurity provider. Cloudflare Partner, UniFi specialist, 24/7 emergency response. Serving Logan, Tremonton, Brigham City, Preston, and northern Utah."
>
  <!-- ============ SECTION 1 · HERO ============ -->
  <section class="relative">
    <!-- Decorative topology SVG on the right — the original AllTech motif:
         concentric square frames (squares not circles, distinct from
         Cloudflare) with node dots at the intersections and a crosshair
         through the center. A quiet background accent, not a foreground
         illustration. -->
    <svg
      class="hidden lg:block absolute right-0 top-1/2 -translate-y-1/2 -z-0 opacity-50 pointer-events-none"
      width="560" height="560" viewBox="0 0 560 560" fill="none" aria-hidden="true"
    >
      <!-- Concentric square frames -->
      <rect x="60"  y="60"  width="440" height="440" rx="6" stroke="rgba(236,140,0,0.12)" stroke-width="1" stroke-dasharray="2 4" />
      <rect x="110" y="110" width="340" height="340" rx="6" stroke="rgba(236,140,0,0.16)" stroke-width="1" stroke-dasharray="2 4" />
      <rect x="180" y="180" width="200" height="200" rx="6" stroke="rgba(236,140,0,0.20)" stroke-width="1" />

      <!-- Node dots at the intersections -->
      <g fill="rgba(236,140,0,0.55)">
        <circle cx="60"  cy="60"  r="3" />
        <circle cx="500" cy="60"  r="3" />
        <circle cx="60"  cy="500" r="3" />
        <circle cx="500" cy="500" r="3" />
        <circle cx="110" cy="110" r="2" />
        <circle cx="450" cy="110" r="2" />
        <circle cx="110" cy="450" r="2" />
        <circle cx="450" cy="450" r="2" />
        <circle cx="280" cy="280" r="4" fill="rgba(236,140,0,0.9)" />
      </g>

      <!-- Crosshair through center node -->
      <line x1="280" y1="180" x2="280" y2="380" stroke="rgba(236,140,0,0.15)" stroke-width="1" />
      <line x1="180" y1="280" x2="380" y2="280" stroke="rgba(236,140,0,0.15)" stroke-width="1" />
    </svg>

    <div class="relative container-wide pt-24 pb-32 lg:pt-32 lg:pb-40">
      <div class="max-w-3xl">
        <div class="eyebrow mb-5">Managed IT · Cybersecurity · Northern Utah</div>

        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.95] tracking-tight" style="color: var(--color-text-primary)">
          IT and <span style="color: var(--color-amber-400)">cybersecurity</span>,<br />
          run by a real <span style="color: var(--color-amber-400)">team</span>.
        </h1>

        <p class="mt-7 text-xl max-w-2xl leading-relaxed" style="color: var(--color-text-default)">
          AllTech designs, deploys, and runs the infrastructure that keeps Northern Utah
          businesses online and secure — from UniFi networks to full Cloudflare Zero Trust rollouts.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a href="/assessment" class="btn btn-primary">
            Take the free security gap assessment
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="mt-14 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm" style="color: var(--color-text-muted)">
          <div>Local since 2009</div>
          <div>Cloudflare Partner</div>
          <div>UniFi specialist</div>
          <div>24/7 Emergency Response</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SECTION 2 · WHAT WE DO (value statement + services) ============ -->
  <section id="services" class="py-24 lg:py-32 scroll-mt-20">
    <div class="container-wide">
      <SegmentHeader index="01" label="What we do" />
      <div class="max-w-2xl mb-14">
        <h2 class="text-4xl lg:text-5xl font-bold leading-tight">
          What we do.<br />
          <span style="color: var(--color-amber-400)">Delivered in-house.</span>
        </h2>
        <p class="mt-5 text-lg leading-relaxed" style="color: var(--color-text-default)">
          Every one of these is handled by engineers who specialize in it —
          not a subcontractor, not an overseas call center. Pick a service to see how we deliver it.
        </p>
      </div>

      <!-- Featured Cloudflare card -->
      {featured && (
        <a
          href={`/services/${featured.slug}`}
          class="card-amber group block mb-5 p-8 lg:p-10 relative overflow-hidden"
        >
          <div class="absolute top-0 right-0 w-80 h-80 rounded-full blur-3xl pointer-events-none" style="background: rgba(236,140,0,0.12)"></div>
          <div class="relative grid lg:grid-cols-12 gap-6 items-center">
            <div class="lg:col-span-8">
              <Icon name={featured.icon} size={40} class="mb-4" />
              <div class="eyebrow mb-3">Featured · Cloudflare Partner</div>
              <h3 class="font-display text-3xl lg:text-4xl font-bold mb-3" style="color: var(--color-text-primary)">
                {featured.name}
              </h3>
              <p class="text-lg leading-relaxed max-w-2xl" style="color: var(--color-text-default)">{featured.short}</p>
            </div>
            <div class="lg:col-span-4 flex flex-col items-start lg:items-end gap-4">
              <!-- Small "status dashboard" mockup — what a deployed Zero Trust
                   rollout actually looks like, not another icon. -->
              <svg width="200" height="110" viewBox="0 0 200 100" fill="none" aria-hidden="true" class="w-full max-w-[200px]">
                <rect x="0" y="0" width="200" height="100" rx="10" fill="var(--color-bg-surface)" stroke="var(--color-amber-300)" stroke-width="1.5" />
                <circle cx="20" cy="24" r="4" fill="var(--color-teal-500)" />
                <text x="32" y="28" font-family="var(--font-mono)" font-size="11" fill="var(--color-text-default)">Tunnel</text>
                <circle cx="110" cy="24" r="4" fill="var(--color-teal-500)" />
                <text x="122" y="28" font-family="var(--font-mono)" font-size="11" fill="var(--color-text-default)">WARP</text>
                <circle cx="20" cy="58" r="4" fill="var(--color-teal-500)" />
                <text x="32" y="62" font-family="var(--font-mono)" font-size="11" fill="var(--color-text-default)">Gateway</text>
                <circle cx="110" cy="58" r="4" fill="var(--color-teal-500)" />
                <text x="122" y="62" font-family="var(--font-mono)" font-size="11" fill="var(--color-text-default)">Access</text>
                <rect x="14" y="78" width="172" height="6" rx="3" fill="var(--color-teal-500)" opacity="0.85" />
              </svg>
              <span class="inline-flex items-center gap-2 font-medium text-sm group-hover:gap-3 transition-all" style="color: var(--color-amber-600)">
                Explore Zero Trust
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </div>
        </a>
      )}

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {rest.map((service) => {
          const { href, external } = serviceLink(service);
          return (
            <a
              href={href}
              class="card group block"
              {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <Icon name={service.icon} size={32} class="mb-3" />
              <h3 class="font-display text-xl font-bold mb-2 group-hover:text-[var(--color-amber-600)] transition" style="color: var(--color-text-primary)">
                {service.name}
              </h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-default)">{service.short}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium" style="color: var(--color-amber-600)">
                {external ? 'Visit site' : 'Learn more'} <span aria-hidden="true">{external ? '↗' : '→'}</span>
              </span>
            </a>
          );
        })}
      </div>

      <div class="mt-12 flex flex-wrap items-center gap-3">
        <a href="/contact" class="btn btn-primary">Start a conversation</a>
        <a href={`tel:${site.phoneE164}`} class="btn btn-ghost font-mono">{site.phone}</a>
      </div>
    </div>
  </section>

  <!-- ============ SECTION 3 · WHY ALLTECH (differentiation + P/P/P) ============ -->
  <section class="py-24 lg:py-32 scroll-mt-20">
    <div class="container-wide">
      <SegmentHeader index="02" label="Why AllTech" />
      <div class="max-w-2xl mb-14">
        <h2 class="text-4xl lg:text-5xl font-bold leading-tight">
          Proactive. Preventative.<br />
          <span style="color: var(--color-amber-400)">Professional.</span>
        </h2>
        <p class="mt-5 text-lg leading-relaxed" style="color: var(--color-text-default)">
          A lot of small businesses run on one IT guy. When he's out sick, on
          vacation, or gone, so is your support. AllTech is a full team —
          so there's always someone who knows your systems.
        </p>
      </div>

      <!-- P / P / P as one connected illustration — this section's visual
           centerpiece — instead of three small icon-cards repeating
           Section 01's card pattern. The real descriptive copy lives in the
           HTML caption row below the (aria-hidden) illustration. -->
      <div class="mb-8 -mx-2 overflow-x-auto">
        <svg viewBox="0 0 920 200" fill="none" aria-hidden="true" class="w-full min-w-[720px] h-auto">
          <defs>
            <filter id="ppp-shadow" x="-50%" y="-50%" width="220%" height="220%">
              <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#0a0f1a" flood-opacity="0.08" />
            </filter>
          </defs>

          <rect x="0" y="15" width="260" height="170" rx="14" fill="var(--color-bg-surface)" stroke="var(--color-border-default)" stroke-width="1.5" filter="url(#ppp-shadow)" />
          <rect x="20" y="35" width="36" height="5" rx="2.5" fill="var(--color-amber-400)" />
          <g transform="translate(102,58)">
            <rect x="0" y="0" width="56" height="56" rx="8" stroke="var(--color-amber-500)" stroke-width="2" stroke-dasharray="3 4" />
            <rect x="14" y="14" width="28" height="28" rx="5" stroke="var(--color-amber-500)" stroke-width="2" />
            <circle cx="28" cy="28" r="4" fill="var(--color-amber-500)" />
          </g>
          <text x="130" y="165" text-anchor="middle" font-family="var(--font-display)" font-weight="700" font-size="20" fill="var(--color-text-primary)">Proactive</text>

          <line x1="270" y1="100" x2="312" y2="100" stroke="var(--color-slate-400)" stroke-width="2" />
          <path d="M306 93l10 7l-10 7" stroke="var(--color-slate-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />

          <rect x="330" y="15" width="260" height="170" rx="14" fill="var(--color-bg-surface)" stroke="var(--color-border-default)" stroke-width="1.5" filter="url(#ppp-shadow)" />
          <rect x="350" y="35" width="36" height="5" rx="2.5" fill="var(--color-amber-400)" />
          <g transform="translate(432,58)">
            <rect x="2" y="22" width="32" height="32" rx="5" stroke="var(--color-amber-500)" stroke-width="2" />
            <rect x="22" y="2" width="32" height="32" rx="5" fill="var(--color-bg-surface)" stroke="var(--color-amber-500)" stroke-width="2" />
          </g>
          <text x="460" y="165" text-anchor="middle" font-family="var(--font-display)" font-weight="700" font-size="20" fill="var(--color-text-primary)">Preventative</text>

          <line x1="600" y1="100" x2="642" y2="100" stroke="var(--color-slate-400)" stroke-width="2" />
          <path d="M636 93l10 7l-10 7" stroke="var(--color-slate-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />

          <rect x="660" y="15" width="260" height="170" rx="14" fill="var(--color-bg-surface)" stroke="var(--color-border-default)" stroke-width="1.5" filter="url(#ppp-shadow)" />
          <rect x="680" y="35" width="36" height="5" rx="2.5" fill="var(--color-amber-400)" />
          <g transform="translate(750.9,49.4) scale(2.444)">
            <path d="M16 3.5L25.5 7.5V14.5C25.5 20.5 21.5 25.6 16 28C10.5 25.6 6.5 20.5 6.5 14.5V7.5Z" fill="var(--color-bg-tint)" stroke="var(--color-amber-500)" stroke-width="0.82" stroke-linejoin="round" />
            <path d="M12 15.5l2.8 2.8l5.2-6" stroke="var(--color-amber-600)" stroke-width="1.02" stroke-linecap="round" stroke-linejoin="round" />
          </g>
          <text x="790" y="165" text-anchor="middle" font-family="var(--font-display)" font-weight="700" font-size="20" fill="var(--color-text-primary)">Professional</text>
        </svg>
      </div>
      <!-- Grid columns mirror the SVG panels' exact proportions (260:70:260:70:260
           units) via matching percentages + space-between, so captions stay
           aligned under their panel at every viewport instead of drifting
           against the illustration's independently-scaled coordinates. -->
      <div
        class="grid gap-5 sm:gap-0 mb-14 pb-14 sm:justify-between sm:[grid-template-columns:28.26%_28.26%_28.26%]"
        style="border-bottom: 1px solid var(--color-border-subtle)"
      >
        <p class="text-sm leading-relaxed" style="color: var(--color-text-default)"><strong class="sm:hidden" style="color: var(--color-text-primary)">Proactive — </strong>We monitor, patch, and harden before problems start — not after the call comes in.</p>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-default)"><strong class="sm:hidden" style="color: var(--color-text-primary)">Preventative — </strong>Layered security built on real frameworks (CIS, NIST), continually updated to stop threats you haven’t seen yet.</p>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-default)"><strong class="sm:hidden" style="color: var(--color-text-primary)">Professional — </strong>Documented, accountable, and responsive — a team that shows up, communicates, and follows through.</p>
      </div>

      <!-- What sets us apart from a one-person shop — plain list now that the
           section already has its visual centerpiece above. -->
      <div class="grid sm:grid-cols-2 gap-x-10 gap-y-3 max-w-3xl">
        {[
          'A full team of engineers — not a single point of failure',
          'Enterprise tooling: Cloudflare, UniFi, Datto, Microsoft 365',
          '24/7 emergency response',
          'Framework-based and refined as new threats emerge',
          'Local since 2009, on-site when it matters',
        ].map((point) => (
          <div class="flex items-start gap-2.5">
            <svg class="w-5 h-5 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 10.5l3.5 3.5L16 6" stroke="var(--color-amber-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="leading-snug" style="color: var(--color-text-default)">{point}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SECTION 4 · FREE ASSESSMENT ============ -->
  <section class="py-24 lg:py-32 scroll-mt-20">
    <div class="container-wide">
      <SegmentHeader index="03" label="Free assessment" />
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <h2 class="text-4xl lg:text-5xl font-bold leading-tight">
            Not sure where your <span style="color: var(--color-amber-400)">gaps</span> are?
          </h2>
          <p class="mt-5 text-lg leading-relaxed max-w-2xl" style="color: var(--color-text-default)">
            Take our free security gap assessment — a few quick questions across 12 domains,
            from backups and patching to firewalls, identity, and endpoints. You'll get a
            score right away, and we'll follow up to walk through what it means for your business.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href="/assessment" class="btn btn-primary">
              Take the assessment <span aria-hidden="true">→</span>
            </a>
            <a href="/contact" class="btn btn-ghost">Talk to an engineer</a>
          </div>
        </div>

        <!-- A believable results screenshot, not an abstract gauge glyph:
             window chrome, a real gauge + score, and per-domain rows so it
             reads as "here's what you get," not a decorative icon. -->
        <div class="hidden lg:flex lg:col-span-5 items-center justify-center">
          <svg width="340" height="300" viewBox="0 0 380 330" fill="none" aria-hidden="true">
            <defs>
              <filter id="score-shadow" x="-50%" y="-50%" width="200%" height="200%">
                <feDropShadow dx="0" dy="6" stdDeviation="10" flood-color="#0a0f1a" flood-opacity="0.10" />
              </filter>
            </defs>

            <rect x="0" y="0" width="380" height="330" rx="14" fill="var(--color-bg-surface)" stroke="var(--color-border-default)" stroke-width="1.5" filter="url(#score-shadow)" />
            <rect x="0" y="16" width="380" height="32" fill="var(--color-bg-elevated)" />
            <circle cx="20" cy="32" r="3" fill="var(--color-border-strong)" />
            <circle cx="32" cy="32" r="3" fill="var(--color-border-strong)" />
            <circle cx="44" cy="32" r="3" fill="var(--color-border-strong)" />
            <text x="64" y="36" font-family="var(--font-mono)" font-size="11" fill="var(--color-text-subtle)">Security Gap Assessment</text>

            <path d="M130 140a60 60 0 0 1 120 0" stroke="var(--color-border-default)" stroke-width="14" stroke-linecap="round" />
            <path d="M130 140a60 60 0 0 1 106-38.6" stroke="var(--color-amber-500)" stroke-width="14" stroke-linecap="round" />
            <line x1="190" y1="140" x2="225" y2="110" stroke="var(--color-amber-600)" stroke-width="3" stroke-linecap="round" />
            <circle cx="190" cy="140" r="5" fill="var(--color-amber-600)" />
            <text x="190" y="176" text-anchor="middle" font-family="var(--font-display)" font-weight="700" font-size="34" fill="var(--color-text-primary)">82%</text>
            <text x="190" y="195" text-anchor="middle" font-family="var(--font-mono)" font-size="11" letter-spacing="1" fill="var(--color-text-subtle)">YOUR SCORE</text>

            <text x="20" y="229" font-family="var(--font-sans)" font-size="12" fill="var(--color-text-default)">Backups</text>
            <rect x="110" y="221" width="210" height="6" rx="3" fill="var(--color-border-subtle)" />
            <rect x="110" y="221" width="190" height="6" rx="3" fill="var(--color-teal-500)" />
            <circle cx="332" cy="224" r="4" fill="var(--color-teal-500)" />

            <text x="20" y="257" font-family="var(--font-sans)" font-size="12" fill="var(--color-text-default)">Firewall</text>
            <rect x="110" y="249" width="210" height="6" rx="3" fill="var(--color-border-subtle)" />
            <rect x="110" y="249" width="170" height="6" rx="3" fill="var(--color-teal-500)" />
            <circle cx="332" cy="252" r="4" fill="var(--color-teal-500)" />

            <text x="20" y="285" font-family="var(--font-sans)" font-size="12" fill="var(--color-text-default)">Identity</text>
            <rect x="110" y="277" width="210" height="6" rx="3" fill="var(--color-border-subtle)" />
            <rect x="110" y="277" width="100" height="6" rx="3" fill="var(--color-amber-500)" />
            <circle cx="332" cy="280" r="4" fill="var(--color-amber-500)" />
          </svg>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
