    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-dasharray: 120 520;   /* one 120-long segment over pathLength 640 */
    stroke-dashoffset: 0;
    opacity: 0;
  }
  .orbit-a { animation: ctaOrbitSweep 4.8s linear infinite; }
  .orbit-b { stroke: rgba(231, 152, 23, 0.30); animation: ctaOrbitSweep 5.6s linear infinite 1.1s; }
  .orbit-c { stroke: rgba(231, 152, 23, 0.22); animation: ctaOrbitSweep 6.4s linear infinite 2s; }

  .orbit-dot {
    fill: rgba(244, 156, 9, 0.8);
    opacity: 0;
