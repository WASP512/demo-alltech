---
import BaseLayout from '~/layouts/BaseLayout.astro';

/**
 * Our Team.
 *
 * Currently a blank page — no employees are listed yet. When real people are
 * added, this renders a condensed roster: a row of name buttons, and clicking
 * a name reveals that person's photo + bio (the click-to-reveal pattern seen
 * under "Support from people who know you" on nextmeters.com).
 *
 * To add someone, drop an object into `team` below and put their photo in
 * /public/team/ (e.g. "/team/jane-doe.jpg"). The interaction wires up
 * automatically.
 */
interface Member {
  name: string;
  role: string;
  photo: string; // path under /public, e.g. "/team/jane-doe.jpg"
  bio: string;
  funnyBlurb?: string; // a lighthearted one-liner shown under the bio
}

const team: Member[] = [
  // Example shape (uncomment and fill in once headshots + bios are ready):
  // {
  //   name: 'Jane Doe',
  //   role: 'Lead Network Engineer',
  //   photo: '/team/jane-doe.jpg',
  //   bio: 'Short bio — background, focus areas, and what Jane handles for clients.',
  //   funnyBlurb: 'Will reorganize your patch panel and your snack drawer.',
  // },
];
---

<BaseLayout
  title="Our Team"
  description="Meet the engineers behind AllTech — the team that designs, deploys, and runs IT, cybersecurity, and network infrastructure for businesses across Northern Utah."
>
  <section class="surface-dark bg-motif relative overflow-hidden">
    <div class="glow-amber" style="top: -200px; right: -100px;"></div>
    <div class="relative container-wide py-16 lg:py-20">
      <div class="eyebrow mb-4">Our Team</div>
      <h1 class="font-display text-5xl lg:text-6xl font-bold leading-tight max-w-3xl">
        The people who <span style="color: var(--color-amber-400);">build and run</span> your infrastructure.
      </h1>
      <p class="mt-6 text-xl max-w-2xl leading-relaxed text-muted">
        Real engineers, local since 2009. When you call AllTech, you reach the
        same people who designed your network — not a faceless queue.
      </p>
    </div>
  </section>

  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-wide">
      {team.length === 0 ? (
        <div class="max-w-xl">
          <h2 class="font-display text-2xl font-bold mb-3" style="color: var(--color-text-primary);">
            Team profiles are coming soon.
          </h2>
          <p class="text-muted leading-relaxed">
            We're putting together photos and bios for the people you'll work with.
            In the meantime, reach out and we'll connect you with the right engineer.
          </p>
          <a href="/contact" class="btn btn-primary mt-6">Get in touch</a>
        </div>
      ) : (
        <div id="team-roster">
          <p class="eyebrow mb-4">Select a name</p>
          <div class="flex flex-wrap gap-2" role="tablist" aria-label="Team members">
            {team.map((m, i) => (
              <button
                type="button"
                class="team-name btn btn-ghost"
                data-index={i}
                role="tab"
                aria-controls={`member-${i}`}
                aria-selected={i === 0 ? 'true' : 'false'}
              >
                {m.name}
              </button>
            ))}
          </div>

          <div class="mt-8">
            {team.map((m, i) => (
              <div
                id={`member-${i}`}
                class="team-panel card max-w-2xl"
                data-index={i}
                role="tabpanel"
                hidden={i !== 0}
              >
                <div class="flex flex-col sm:flex-row gap-6 items-start">
                  <img
                    src={m.photo}
                    alt={m.name}
                    class="w-28 h-28 rounded-full object-cover shrink-0"
                    loading="lazy"
                  />
                  <div>
                    <h2 class="font-display text-xl font-bold" style="color: var(--color-text-primary);">{m.name}</h2>
                    <div class="text-sm font-medium mb-3" style="color: var(--color-amber-600);">{m.role}</div>
                    <p class="text-muted leading-relaxed">{m.bio}</p>
                    {m.funnyBlurb && (
                      <p class="mt-3 text-sm italic" style="color: var(--color-amber-600);">“{m.funnyBlurb}”</p>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .team-name[aria-selected="true"] {
    background: var(--color-amber-400);
    color: var(--color-ink-950);
    border-color: var(--color-amber-400);
  }
</style>

<script>
  // Click-to-reveal roster: a name button shows that member's photo + bio.
  const roster = document.getElementById('team-roster');
  if (roster) {
    const buttons = Array.from(roster.querySelectorAll<HTMLButtonElement>('.team-name'));
    const panels = Array.from(roster.querySelectorAll<HTMLElement>('.team-panel'));

    const activate = (index: number) => {
      buttons.forEach((b) =>
        b.setAttribute('aria-selected', b.dataset.index === String(index) ? 'true' : 'false'),
      );
      panels.forEach((p) => {
        p.hidden = p.dataset.index !== String(index);
      });
    };

    buttons.forEach((b) =>
      b.addEventListener('click', () => activate(Number(b.dataset.index))),
    );
  }
</script>
