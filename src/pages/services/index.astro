---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { services } from '~/lib/site';
---

<BaseLayout
  title="IT Services & Cybersecurity in Northern Utah"
  description="Managed IT, cybersecurity, Cloudflare Zero Trust, UniFi network design, and Microsoft 365 services for businesses in Northern Utah and the Wasatch Front."
>
  <section class="surface-dark bg-motif relative overflow-hidden">
    <div class="glow-amber" style="top: -200px; right: -100px;"></div>
    <div class="relative container-wide py-16 lg:py-20">
      <div class="eyebrow mb-4">Services</div>
      <h1 class="font-display text-5xl lg:text-6xl font-semibold leading-tight max-w-3xl">
        Everything you need to run a <span style="color: var(--color-amber-400);">modern business network</span>.
      </h1>
      <p class="mt-6 text-xl max-w-2xl leading-relaxed text-muted">
        Pick a service to learn how we deliver it, or send us a note describing
        what you're trying to fix.
      </p>
    </div>
  </section>

  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-wide grid md:grid-cols-2 gap-5">
      {services.map((service) => (
        <a href={`/services/${service.slug}`} class="card group block p-7">
          {service.featured && (
            <div class="eyebrow mb-2">Cloudflare Partner</div>
          )}
          <h2 class="font-display text-2xl font-semibold mb-3 transition-colors">
            <span class="group-hover:text-amber-300" style="color: var(--color-text-primary);">{service.name}</span>
          </h2>
          <p class="leading-relaxed text-muted">{service.short}</p>
          <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium" style="color: var(--color-amber-300);">
            Read more <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
