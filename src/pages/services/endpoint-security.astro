---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { site } from '~/lib/site';

const whatYouGet = [
  ['Someone Is Watching', "Every protected device reports activity to our monitoring platform. Events are reviewed against known attack patterns and unusual behavior — not left to pile up in a log nobody reads."],
  ['Catch Suspicious Behavior Early', "Modern attacks don't always rely on known malware. We watch how systems behave — activity associated with ransomware, credential theft, and unauthorized access — not just whether a file matches a known virus."],
  ['Real Investigation, Not Just Alerts', 'Monitoring tools can generate thousands of notifications a day. We filter the noise, correlate related events, and focus on activity that actually needs a person to look at it.'],
  ['Protection Stays Consistent', 'Monitoring is deployed and managed the same way across your environment, so a laptop set up last week gets the same protection as the server that has been running for years.'],
  ["See What's Happening", "You get reporting that shows what's protected, what's been flagged, and what needs attention — not a pile of raw logs you'd need a security analyst to decode."],
  ['Limit the Damage', "When something looks wrong, we investigate the affected system, isolate the device if needed, and work to contain the issue before it spreads to the rest of your network."],
];

const whatWeInvestigate = [
  "Malware that a signature-based scanner wouldn't have caught",
  "A sign-in attempt from a location or device that doesn't match how someone normally works",
  'Activity consistent with an attacker trying to steal saved credentials',
  'A link or attachment tied to an active phishing campaign',
  'Software installed on a device without going through IT',
  "A remote access tool showing up on a device that shouldn't have one",
  "PowerShell commands being used in ways that don't match normal admin activity",
  'A device trying to communicate with an address already known to be malicious',
];

const steps = [
  ['01', 'Something Gets Flagged', "An unfamiliar process, a login from somewhere it shouldn't be, a file behaving strangely — monitoring catches activity that doesn't fit the normal pattern."],
  ['02', 'We Review It', "Most flagged activity turns out to be harmless: a software update, an employee on a new device. We look at it before it ever becomes your problem."],
  ['03', 'We Investigate', "When something doesn't check out, we dig into what happened, what it touched, and whether it's still active."],
  ['04', 'We Contain It', "If it's real, we isolate the affected device and work to stop it from reaching the rest of your network."],
  ['05', 'We Remediate', 'We clean up what the incident touched and get the system back to a known-good state.'],
  ['06', 'We Call You', "You hear it from a person, with a plain explanation of what happened and what we did — not an automated alert you find three days later."],
];

const inPractice = [
  ['Constant', 'Devices report activity around the clock, not just during business hours.'],
  ['Automated first', 'The bulk of that activity is filtered and prioritized automatically — no person could read all of it by hand.'],
  ['Reviewed by people', "What's left after filtering gets a human look before anything reaches your inbox."],
];

const audience = [
  ['An Employee Working From Home', "Remote employees have access to the same email, files, and business applications as anyone in the office. We monitor and protect the device whether it's on your network or connected from a kitchen table."],
  ['A Manufacturing PC Running Critical Software', 'Production systems and specialty equipment can be expensive and slow to replace when something goes wrong. Monitoring helps catch suspicious activity before it turns into a line-down problem.'],
  ['A Multi-Location Business Without IT Staff at Every Site', "Not every office has someone who can tell a real problem from a pop-up ad. Every location gets monitored the same way, whether there's IT staff on-site or not."],
  ['A Healthcare Office Handling Patient Records', 'Scheduling systems, insurance portals, and patient records carry real regulatory weight if they\'re exposed. We monitor those workstations accordingly.'],
  ['A Law Firm or Accounting Practice', "Client confidentiality isn't optional in professional services. Endpoint monitoring is part of showing clients — and your malpractice insurer — that you take it seriously."],
  ['A Growing Business Without a Security Team', "Most small businesses don't have someone reviewing security alerts all day. We provide the monitoring and response most organizations can't justify staffing for internally."],
  ['A Nonprofit Running Lean', 'Small staff, tight budget, and donor data that still needs protecting. We provide the same monitoring larger organizations pay a full security team for.'],
  ['Organizations Facing Compliance Requirements', 'Cyber insurance carriers and auditors increasingly ask for proof of endpoint monitoring. We provide the documentation and visibility to answer that question directly.'],
];

const related = [
  ['Managed Detection & Response (MDR)', 'Endpoint alerts become more valuable when combined with security analysts, threat intelligence, and incident investigation workflows.', '/services/cybersecurity#soc'],
  ['Security Awareness Training', 'Many attacks begin with phishing emails or user mistakes. Training helps reduce the number of threats that ever reach the endpoint.', '/services/cybersecurity'],
  ['Vulnerability Management', 'Identifying missing patches and known weaknesses reduces opportunities for attackers and strengthens endpoint protection.', '/services/cybersecurity'],
  ['Zero Trust Network Access (ZTNA)', 'Secure remote access reduces reliance on traditional VPNs and helps control access to internal systems.', '/services/cloudflare-zero-trust'],
];

const contactHref = '/contact?service=Cybersecurity';
---

<BaseLayout
  title="Endpoint Security & Ransomware Protection"
  description="Endpoint security and ransomware protection for businesses across Northern Utah. AllTech monitors every managed workstation and server, investigates suspicious activity, and helps contain incidents before they spread."
>
  <!-- Hero -->
  <section class="surface-dark relative overflow-hidden">
    <div class="glow-amber" style="top: -200px; right: -100px;"></div>
    <div class="relative container-wide py-16 lg:py-20">
      <div class="max-w-3xl">
        <div class="eyebrow mb-4">Endpoint Security &amp; Ransomware Protection</div>
        <h1 class="font-display text-5xl lg:text-6xl font-semibold leading-[0.95] tracking-tight">
          Your employees work.<br />
          <span style="color: var(--color-amber-400);">We watch for the threats.</span>
        </h1>
        <p class="mt-6 text-xl leading-relaxed text-muted">
          A ransomware attack usually starts on one laptop and spreads from there. We keep
          eyes on every managed workstation and server, catch suspicious activity early, and
          move fast to contain it before it becomes a bigger problem for your business.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={contactHref} class="btn btn-primary">Schedule an assessment <span aria-hidden="true">→</span></a>
          <a href={`tel:${site.phoneE164}`} class="btn btn-ghost font-mono">{site.phone}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Most security problems start on a device -->
  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-prose">
      <div class="eyebrow mb-4">The problem</div>
      <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
        Most security problems start on a device
      </h2>
      <div class="mt-6 space-y-5 text-lg leading-relaxed text-muted">
        <p>The laptop in accounting, the warehouse PC running production software, or the employee working from home are often the first targets in a cyberattack.</p>
        <p>When those devices aren't monitored, malicious activity can go unnoticed until files are encrypted, accounts are compromised, or operations stop.</p>
        <p>AllTech deploys endpoint monitoring across your managed devices and reviews the alerts that matter — so your team isn't left sorting through security notifications on its own.</p>
      </div>
    </div>
  </section>

  <!-- What you get -->
  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-wide">
      <div class="max-w-2xl mb-12">
        <div class="eyebrow mb-4">What you get</div>
        <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
          Monitoring, investigation, and response
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Delivered through our monitoring platform (built on Datto EDR and RocketCyber) —
          deployed and managed by us, not something you have to configure yourself.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {whatYouGet.map(([title, body]) => (
          <div class="card">
            <h3 class="font-display text-lg font-bold mb-2" style="color: var(--color-text-primary);">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-default);">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What we actually investigate -->
  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-prose">
      <div class="eyebrow mb-4">What we actually investigate</div>
      <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
        The activity that gets a second look
      </h2>
      <div class="mt-6 space-y-5 text-lg leading-relaxed text-muted">
        <p>Most of what our monitoring flags turns out to be nothing — a legitimate script, a new device, an update running on schedule. A small percentage of it isn't, and that's what we spend our time on. A few examples of what actually lands on an engineer's desk:</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-x-10 gap-y-2.5 mt-8 not-prose">
        {whatWeInvestigate.map((item) => (
          <div class="flex items-start gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-[2px] shrink-0" style="background: var(--color-amber-500)"></span>
            <span class="leading-snug text-muted">{item}</span>
          </div>
        ))}
      </div>
      <p class="mt-8 text-lg leading-relaxed text-muted">
        Most of the time, it's explainable. When it isn't, having eyes on it early is the
        difference between a contained incident and a much longer, more expensive one.
      </p>
    </div>
  </section>

  <!-- Why traditional AV isn't enough -->
  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-prose">
      <div class="eyebrow mb-4">Beyond antivirus</div>
      <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
        Why traditional antivirus isn't enough
      </h2>
      <div class="mt-6 space-y-5 text-lg leading-relaxed text-muted">
        <p>Traditional antivirus is built to catch <em>known</em> threats — it checks a file against a list of signatures for viruses that have already been identified. That still matters, and we keep it running. But attackers change their tools constantly, and a lot of modern attacks don't use anything that shows up on that list.</p>
        <p>What matters more is behavior: does a process suddenly start encrypting files, harvesting saved credentials, or launching commands it has no business running? Watching for that — instead of only checking files against a known-bad list — is what catches an attack while it's still small enough to contain.</p>
        <p>The goal isn't a tool that promises to stop everything. It's visibility early enough that we still have real options before an incident becomes a business problem.</p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-wide">
      <div class="max-w-2xl mb-12">
        <div class="eyebrow mb-4">How it works</div>
        <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
          What happens when something looks suspicious
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {steps.map(([n, title, body]) => (
          <div class="card">
            <div class="font-display text-2xl font-bold mb-2" style="color: var(--color-amber-500);">{n}</div>
            <h3 class="font-display text-base font-bold mb-2" style="color: var(--color-text-primary);">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-default);">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What monitoring actually looks like (stats) -->
  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-wide">
      <div class="max-w-2xl mb-10">
        <div class="eyebrow mb-4">In practice</div>
        <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
          What monitoring looks like in practice
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Most of what monitoring picks up is normal — a legitimate software update, an IT
          script running on schedule, an employee logging in from a new laptop. Across a
          fleet of devices, there's more of that activity than any person could review by hand.
        </p>
      </div>
      <div class="grid sm:grid-cols-3 gap-4">
        {inPractice.map(([label, body]) => (
          <div class="card">
            <h3 class="font-display text-lg font-bold mb-2" style="color: var(--color-text-primary);">{label}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-default);">{body}</p>
          </div>
        ))}
      </div>
      <p class="mt-8 text-muted leading-relaxed max-w-2xl">
        Our job is separating that normal noise from the handful of events that actually
        need a person to look at them — and making sure those don't get buried.
      </p>
    </div>
  </section>

  <!-- Who this is for -->
  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-wide">
      <div class="max-w-2xl mb-12">
        <div class="eyebrow mb-4">Who this is for</div>
        <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
          Built for real environments
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {audience.map(([title, body]) => (
          <div class="card">
            <h3 class="font-display text-lg font-bold mb-2" style="color: var(--color-text-primary);">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-default);">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What we don't do -->
  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-prose">
      <div class="eyebrow mb-4">Honest expectations</div>
      <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
        What we don't do
      </h2>
      <div class="mt-6 space-y-5 text-lg leading-relaxed text-muted">
        <p>We don't claim software alone stops every attack, and we're not going to pretend it does to make a sale.</p>
        <p>Endpoint monitoring is one layer. It works best alongside patch management (fewer holes to exploit), immutable backups (so a bad day doesn't become a business-ending one), security awareness training (fewer threats ever reach a device), and identity protections like multi-factor authentication (so a stolen password isn't enough to get in).</p>
        <p>We also believe in having an incident response plan before you need one — who gets called, what gets isolated, and how you communicate with your team and customers if something happens.</p>
        <p>Our goal isn't to promise you'll never have an incident. It's to reduce the odds, catch it early when we can, and know exactly what to do when we can't.</p>
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="surface-dark py-16 lg:py-20" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-wide">
      <div class="max-w-2xl mb-12">
        <div class="eyebrow mb-4">Related services</div>
        <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
          Endpoint security works best in layers
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {related.map(([title, body, href]) => (
          <a href={href} class="card group block">
            <h3 class="font-display text-lg font-bold mb-2 group-hover:text-[var(--color-amber-600)] transition" style="color: var(--color-text-primary);">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-default);">{body}</p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium" style="color: var(--color-amber-600);">Learn more <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="surface-dark py-16 lg:py-24" style="border-top: 1px solid var(--color-line-faint);">
    <div class="container-wide">
      <div class="max-w-3xl">
        <h2 class="font-display text-3xl lg:text-4xl font-bold leading-tight" style="color: var(--color-text-primary);">
          Know which devices are protected — <span style="color: var(--color-amber-400);">and which aren't</span>.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-muted">
          We'll review your workstations, laptops, servers, and existing security tools, identify
          coverage gaps, and provide practical recommendations that fit your business.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={contactHref} class="btn btn-primary">Schedule an endpoint security assessment <span aria-hidden="true">→</span></a>
          <a href={`tel:${site.phoneE164}`} class="btn btn-ghost font-mono">{site.phone}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
