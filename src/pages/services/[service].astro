---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { services, site } from '~/lib/site';

export function getStaticPaths() {
  return services
    .filter((s) => !['cloudflare-zero-trust', 'cybersecurity'].includes(s.slug))
    .map((s) => ({ params: { service: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
---

<BaseLayout title={service.name} description={service.short}>
  <section class="surface-dark bg-motif relative overflow-hidden">
    <div class="glow-amber" style="top: -200px; right: -100px;"></div>
    <div class="relative container-wide py-16 lg:py-20">
      <div class="eyebrow mb-4">Service</div>
      <h1 class="font-display text-5xl lg:text-6xl font-semibold leading-tight max-w-3xl">{service.name}</h1>
      <p class="mt-6 text-xl max-w-2xl leading-relaxed text-muted">{service.short}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={`/contact?service=${encodeURIComponent(service.name)}`} class="btn btn-primary">Scope an engagement</a>
      </div>
    </div>
  </section>

  <section class="surface-dark py-20">
    <div class="container-prose">
      <div class="card p-8 lg:p-10">
        <p class="leading-relaxed text-muted">
          Detailed page content coming soon. In the meantime, give us a call at{' '}
          <a href={`tel:${site.phoneE164}`} class="font-mono" style="color: var(--color-amber-300);">{site.phone}</a>{' '}
          or <a href="/contact" style="color: var(--color-amber-300);">send a message</a> and an
          engineer will walk you through how we approach {service.name.toLowerCase()}.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
