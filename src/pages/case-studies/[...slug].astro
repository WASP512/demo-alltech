---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies', ({ data }) => !data.draft);
  return studies.map((s) => ({ params: { slug: s.slug }, props: { study: s } }));
}

interface Props { study: CollectionEntry<'caseStudies'> }
const { study } = Astro.props;
const { Content } = await study.render();
---

<BaseLayout title={study.data.title} description={study.data.summary}>
  <article class="surface-dark py-16">
    <div class="container-prose">
      <a href="/case-studies" class="text-sm font-medium" style="color: var(--color-amber-300);">← Back to case studies</a>

      <header class="mt-6 mb-10">
        <div class="text-xs font-mono mb-4" style="color: var(--color-amber-300);">{study.data.industry} · {study.data.client}</div>
        <h1 class="font-display text-4xl lg:text-5xl font-semibold leading-tight">{study.data.title}</h1>
        <p class="mt-4 text-xl leading-relaxed text-muted">{study.data.summary}</p>

        <div class="mt-6 flex flex-wrap gap-2">
          {study.data.services.map((tag) => (
            <span class="text-xs px-2 py-1 rounded font-medium" style="background: var(--color-surface-3); color: var(--color-text-secondary);">{tag}</span>
          ))}
        </div>

        <div class="mt-8 p-5 rounded-lg" style="background: var(--color-surface-2); border: 1px solid var(--color-amber-400);">
          <div class="eyebrow mb-2">Outcome</div>
          <p class="font-medium" style="color: var(--color-text-primary);">{study.data.outcome}</p>
        </div>
      </header>

      {study.data.pentestSnippet && (
        <div class="mb-10 rounded-lg overflow-hidden" style="border: 1px solid var(--color-border-subtle);">
          <div class="px-5 py-2 text-[11px] font-mono uppercase tracking-wider" style="background: var(--color-bg-elevated); color: var(--color-text-subtle);">
            Sanitized pentest findings
          </div>
          <pre class="px-5 py-4 text-sm overflow-x-auto whitespace-pre-wrap" style="background: var(--color-bg-surface); color: var(--color-text-default);"><code>{study.data.pentestSnippet}</code></pre>
        </div>
      )}

      <div class="prose-alltech"><Content /></div>

      {study.data.testimonial && (
        <blockquote class="mt-12 border-l-4 pl-6 py-2" style="border-color: var(--color-amber-400);">
          <p class="text-xl lg:text-2xl font-display leading-relaxed" style="color: var(--color-text-primary);">
            “{study.data.testimonial}”
          </p>
          {study.data.testimonialAuthor && (
            <footer class="mt-3 text-sm" style="color: var(--color-text-subtle);">— {study.data.testimonialAuthor}</footer>
          )}
        </blockquote>
      )}
    </div>
  </article>
</BaseLayout>
