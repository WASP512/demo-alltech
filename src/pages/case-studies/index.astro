---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const studies = (await getCollection('caseStudies', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Case Studies"
  description="How AllTech delivers cybersecurity, Cloudflare Zero Trust, and managed IT projects for real businesses across northern Utah."
>
  <section class="surface-dark bg-motif relative overflow-hidden">
    <div class="glow-amber" style="top: -200px; right: -100px;"></div>
    <div class="relative container-wide py-16">
      <div class="eyebrow mb-4">Case Studies</div>
      <h1 class="font-display text-5xl lg:text-6xl font-semibold leading-tight max-w-3xl">
        Real projects, <span style="color: var(--color-amber-300);">real outcomes</span>.
      </h1>
    </div>
  </section>

  <section class="surface-dark py-16">
    <div class="container-prose">
      {studies.length === 0 ? (
        <p class="text-lg text-muted">Case studies coming soon.</p>
      ) : (
        <ul class="space-y-6">
          {studies.map((s) => (
            <li>
              <a href={`/case-studies/${s.slug}`} class="card block group">
                <div class="text-xs font-mono mb-2" style="color: var(--color-amber-300);">{s.data.industry}</div>
                <h2 class="font-display text-2xl font-semibold mb-2 group-hover:text-amber-300 transition-colors">{s.data.title}</h2>
                <p class="text-muted leading-relaxed">{s.data.summary}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {s.data.services.map((tag) => (
                    <span class="text-xs px-2 py-1 rounded font-medium" style="background: var(--color-surface-3); color: var(--color-text-secondary);">{tag}</span>
                  ))}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>
