---
import { site } from '~/lib/site';
import { menuCategories, simpleNavLinks } from '~/lib/menu';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<!--
  Header with a UNIFIED mega-panel.

  All four nav triggers (Cybersecurity / Cloudflare / Network / IT & Cloud)
  share ONE panel. Hovering any trigger reveals the shared panel underneath
  the whole nav. This is the cloudflare.com pattern.

  Implementation: a single .mega-zone wraps the four triggers PLUS the panel.
  CSS (in global.css) reveals the panel when any direct child trigger
  (.mega-trigger) is hovered, or when the panel itself is hovered. No JS.

  The triggers themselves are still clickable links to their category's
  landing page — hover opens the panel, click navigates.
-->

<header class="sticky top-0 z-40 backdrop-blur-xl bg-white/85 border-b border-[var(--color-border-subtle)]">
  <div class="nav-host relative container-wide flex items-center justify-between h-16">
    <!-- Brand -->
    <a href="/" class="flex items-center gap-2.5 font-display font-semibold tracking-tight text-lg" style="color: var(--color-text-primary)">
      <img src="/logo.webp" alt="AllTech logo" class="h-9 w-auto" width="36" height="36" onerror="this.style.display='none'" />
      AllTech
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">

      <!-- ===================================================================
           MEGA ZONE — single "Services" trigger + the shared 4-column panel
           =================================================================== -->
      <div class="mega-zone h-16">
        <a
          href="/services"
          class:list={[
            'mega-trigger flex items-center gap-1 whitespace-nowrap px-3.5 py-2 text-sm font-medium rounded-md transition',
            pathname.startsWith('/services') ? 'text-[var(--color-text-primary)]' : 'text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]',
          ]}
          aria-haspopup="true"
        >
          Services
          <svg class="w-3.5 h-3.5 opacity-60" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>

        <!-- The shared panel. Positioned relative to the header's .nav-host
             container and centered beneath the bar (see global.css). -->
        <div class="mega-panel absolute left-1/2 top-full pt-3 z-50" role="region" aria-label="Services menu">
          <div
            class="rounded-xl shadow-2xl overflow-hidden"
            style="background: var(--color-bg-surface); border: 1px solid var(--color-border-default); box-shadow: 0 24px 64px -16px rgba(0,0,0,0.6);"
          >
            <!-- Columns: one per category, separated by a vertical divider -->
            <div class="grid grid-cols-5 p-6">
              {menuCategories.map((cat) => (
                <div class="min-w-0 flex flex-col px-4 first:pl-0 last:pr-0 border-r last:border-r-0" style="border-color: var(--color-border-subtle)">
                  <div class="mb-2 pb-2 border-b" style="border-color: var(--color-border-subtle)">
                    <a
                      href={cat.href}
                      class="block font-display text-base font-bold tracking-tight hover:text-[var(--color-amber-600)] transition"
                      style="color: var(--color-text-primary);"
                    >
                      {cat.label}
                    </a>
                    {cat.sublabel && (
                      <div class="text-[10px] font-mono uppercase tracking-[0.12em] mt-0.5" style="color: var(--color-text-subtle)">
                        {cat.sublabel}
                      </div>
                    )}
                  </div>
                  <ul class="space-y-0.5">
                    {cat.tiles.map((tile) => (
                      <li>
                        <a
                          href={tile.href}
                          class="group block -mx-2 px-2 py-1.5 rounded-md transition"
                          onmouseenter="this.style.background='var(--color-bg-elevated)'"
                          onmouseleave="this.style.background='transparent'"
                        >
                          <div
                            class="font-medium text-[13px] leading-tight group-hover:text-[var(--color-amber-300)] transition"
                            style="color: var(--color-text-primary);"
                          >
                            {tile.title}
                          </div>
                          <div class="text-[11px] mt-0.5 leading-snug" style="color: var(--color-text-muted)">
                            {tile.description}
                          </div>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            <!-- Footer strip inside the panel -->
            <div
              class="px-6 py-4 flex items-center justify-between border-t"
              style="background: var(--color-bg-page); border-color: var(--color-border-subtle)"
            >
              <span class="text-[11px] font-mono uppercase tracking-[0.18em]" style="color: var(--color-text-subtle)">
                Cloudflare Partner · Northern Utah
              </span>
              <a
                href="/services"
                class="inline-flex items-center gap-1.5 text-xs font-medium transition"
                style="color: var(--color-amber-300)"
              >
                See all services <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Divider + simple links -->
      <div class="mx-3 h-5 w-px" style="background: var(--color-border-subtle)"></div>
      {simpleNavLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'whitespace-nowrap px-3.5 py-2 text-sm font-medium rounded-md transition',
            isActive(link.href) ? 'text-[var(--color-text-primary)]' : 'text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right cluster -->
    <div class="flex items-center gap-3">
      <a
        href={`tel:${site.phoneE164}`}
        class="hidden md:inline text-sm font-mono transition"
        style="color: var(--color-text-muted)"
        onmouseover="this.style.color='var(--color-text-primary)'"
        onmouseout="this.style.color='var(--color-text-muted)'"
      >
        {site.phone}
      </a>
      <a href="/contact" class="btn btn-primary text-sm">Get in touch</a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-nav-toggle"
        class="lg:hidden p-2 rounded-md"
        style="color: var(--color-text-primary); border: 1px solid var(--color-border-default);"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav drawer (mega-menu collapses to accordions per category) -->
  <div
    id="mobile-nav"
    class="lg:hidden hidden border-t"
    style="background: var(--color-bg-surface); border-color: var(--color-border-subtle);"
  >
    <div class="container-wide py-5 space-y-1">
      {menuCategories.map((cat) => (
        <details class="group">
          <summary
            class="flex items-center justify-between cursor-pointer py-3 font-medium"
            style="color: var(--color-text-primary)"
          >
            <span>
              {cat.label}
              {cat.sublabel && <span class="text-xs font-normal ml-2" style="color: var(--color-text-subtle)">{cat.sublabel}</span>}
            </span>
            <svg class="w-4 h-4 transition group-open:rotate-180" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>
          <div class="pl-3 pb-3 space-y-1">
            {cat.tiles.map((tile) => (
              <a
                href={tile.href}
                class="block py-2 text-sm"
                style="color: var(--color-text-muted)"
              >
                {tile.title}
              </a>
            ))}
          </div>
        </details>
      ))}
      <div class="hairline my-3"></div>
      {simpleNavLinks.map((link) => (
        <a href={link.href} class="block py-2.5 font-medium" style="color: var(--color-text-primary)">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-nav-toggle');
  const nav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('hidden');
  });
</script>
