---
import { site } from '~/lib/site';

const nav = [
  { href: '/services', label: 'Services' },
  { href: '/cloudflare', label: 'Cloudflare Partner' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Insights' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-white/85 border-b border-ink-100">
  <div class="container-wide flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 font-display font-semibold text-ink-900 tracking-tight">
      <span class="inline-block w-2 h-2 rounded-full bg-accent-400"></span>
      AllTech
    </a>

    <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm font-medium transition',
            isActive(item.href) ? 'text-ink-900' : 'text-ink-500 hover:text-ink-900',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href={`tel:${site.phoneE164}`} class="hidden sm:inline text-sm font-mono text-ink-600 hover:text-ink-900">
        {site.phone}
      </a>
      <a href="/contact" class="btn btn-primary text-sm">
        Get in touch
      </a>
    </div>
  </div>
</header>
