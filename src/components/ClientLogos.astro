---
/**
 * Client logo marquee, shown site-wide just above the footer.
 *
 * Uses the robust two-group marquee pattern: two identical groups, each at least
 * as wide as the viewport (min-width:100%), both translating -100% in sync — so
 * the row is always full and loops seamlessly on any screen width. Pauses on
 * hover/focus, fades at both edges, and falls back to a static wrapped row for
 * reduced-motion users.
 *
 * Add each logo file to /public/logos/ and append to this array (keep the real
 * file extension — the set is a mix of png/jpeg/webp).
 */
const clients = [
  { src: '/logos/als.jpeg', alt: "AL'S" },
  { src: '/logos/beazer-lock-key.webp', alt: 'Beazer Lock & Key' },
  { src: '/logos/caspers-ice-cream.png', alt: "Casper's Ice Cream" },
  { src: '/logos/ducworks.jpeg', alt: 'Ducworks, Inc.' },
  { src: '/logos/double-l-ranch-meats.png', alt: 'Double L Ranch Meats' },
  { src: '/logos/northern-title.webp', alt: 'Northern Title' },
  { src: '/logos/plastics-resources.webp', alt: 'Plastics Resources Incorporated' },
  { src: '/logos/richmond-utah.jpeg', alt: 'Richmond, Utah' },
  { src: '/logos/spartan.webp', alt: 'Spartan' },
];
---

<!-- Transparent background (no fill) so the page-wide ambient dot grid
     continues through this strip instead of being cut off by a solid band. --><section class="py-12 border-t" style="border-color: var(--color-border-subtle)">
  <p class="text-center eyebrow mb-10">Trusted by dozens of businesses</p>
  <div class="marquee" aria-label="Businesses we serve">
    <ul class="marquee-group">
      {clients.map((c) => (
        <li>
          <img src={c.src} alt={c.alt} class="client-logo" loading="lazy" onerror="this.style.display='none'" />
        </li>
      ))}
    </ul>
    <ul class="marquee-group" aria-hidden="true">
      {clients.map((c) => (
        <li>
          <img src={c.src} alt="" class="client-logo" loading="lazy" onerror="this.style.display='none'" />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .marquee {
    --gap: 3.5rem;
    display: flex;
    gap: var(--gap);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, #000 5%, #000 95%, transparent);
    mask-image: linear-gradient(to right, transparent, #000 5%, #000 95%, transparent);
  }
  .marquee-group {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: var(--gap);
    min-width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    animation: client-marquee 42s linear infinite;
  }
  .marquee:hover .marquee-group,
  .marquee:focus-within .marquee-group {
    animation-play-state: paused;
  }
  .client-logo {
    height: 3.5rem;              /* 56px mobile */
    width: auto;
    max-width: 190px;
    object-fit: contain;
    transition: opacity 0.2s var(--ease-out-soft);
  }
  @media (min-width: 1024px) {
    .client-logo { height: 4.5rem; }  /* 72px desktop — bigger so small logos read */
  }
  @keyframes client-marquee {
    to { transform: translateX(calc(-100% - var(--gap))); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee { mask-image: none; -webkit-mask-image: none; }
    .marquee-group {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      min-width: 0;
      row-gap: 2rem;
    }
    .marquee-group[aria-hidden='true'] { display: none; }
  }
</style>
