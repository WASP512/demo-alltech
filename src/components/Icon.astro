---
/**
 * Shared icon kit — the AllTech illustration system.
 *
 * Every icon is built from the same three primitives used throughout the
 * site: rounded squares (rx=2), circular nodes, and thin connecting lines.
 * No other shape language is introduced. Stroke-only except deliberate solid
 * "status dot" circles. This is the same visual grammar as the hero motif
 * (concentric squares) and the P/P/P pillar icons — this component just
 * formalizes it into a reusable, named set so every section of the site
 * draws from one consistent kit instead of one-off SVGs per page.
 *
 * Usage: <Icon name="shield" size={32} />
 *
 * Colors are deliberately baked into each icon (not overridable via a single
 * `color` prop) because the system uses color *by meaning*: amber marks the
 * thing that matters/is emphasized, teal marks "connected", slate marks
 * neutral hardware. Keeping that mapping inside the icon definitions is what
 * keeps the palette controlled across dozens of usages.
 */
interface Props {
  name:
    | 'node'           // Network & Infrastructure — hub + spokes
    | 'shield'         // Cybersecurity — square tapering to a point + check
    | 'endpoint'       // Managed IT / Endpoint Security — device + status dot
    | 'cloud-sync'     // Microsoft 365 & Cloud — stacked squares + sync marks
    | 'gateway'        // SASE Solutions / Cloudflare Zero Trust — square + keyhole
    | 'disk-recovery'  // Utah Data Recovery — square drive + restore arrow
    | 'camera'         // Install: cameras
    | 'door-access'    // Install: door access
    | 'stack'          // AllTech Top 10 — three layered squares
    | 'dashboard-gauge'; // Assessment / monitoring — screen + gauge + bars
  size?: number;
  class?: string;
}

const { name, size = 32, class: className } = Astro.props;
---

{name === 'node' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <circle cx="16" cy="16" r="3" fill="var(--color-amber-500)" />
    <circle cx="16" cy="6" r="2" stroke="var(--color-teal-500)" stroke-width="1.5" />
    <circle cx="16" cy="26" r="2" stroke="var(--color-teal-500)" stroke-width="1.5" />
    <circle cx="6" cy="16" r="2" stroke="var(--color-teal-500)" stroke-width="1.5" />
    <circle cx="26" cy="16" r="2" stroke="var(--color-teal-500)" stroke-width="1.5" />
    <line x1="16" y1="9" x2="16" y2="13" stroke="var(--color-slate-400)" stroke-width="1.5" stroke-linecap="round" />
    <line x1="16" y1="19" x2="16" y2="23" stroke="var(--color-slate-400)" stroke-width="1.5" stroke-linecap="round" />
    <line x1="9" y1="16" x2="13" y2="16" stroke="var(--color-slate-400)" stroke-width="1.5" stroke-linecap="round" />
    <line x1="19" y1="16" x2="23" y2="16" stroke="var(--color-slate-400)" stroke-width="1.5" stroke-linecap="round" />
  </svg>
)}

{name === 'shield' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <path d="M16 3.5L25.5 7.5V14.5C25.5 20.5 21.5 25.6 16 28C10.5 25.6 6.5 20.5 6.5 14.5V7.5Z" stroke="var(--color-amber-500)" stroke-width="1.5" stroke-linejoin="round" />
    <path d="M12 15.5l2.8 2.8l5.2-6" stroke="var(--color-amber-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}

{name === 'endpoint' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <rect x="7" y="7" width="18" height="13" rx="1.5" stroke="var(--color-slate-500)" stroke-width="1.5" />
    <line x1="4" y1="23.5" x2="28" y2="23.5" stroke="var(--color-slate-500)" stroke-width="1.5" stroke-linecap="round" />
    <circle cx="16" cy="13.5" r="2" fill="var(--color-teal-500)" />
  </svg>
)}

{name === 'cloud-sync' && (
  // Deliberate exception to the square-only rule: a cloud reads instantly in
  // its classic silhouette and not as blocky shapes, and "clear" beats
  // "systematic" here. Cloud silhouette (Lucide-derived geometry, scaled to
  // the 32 box) with a small server rack fully inside it — "hosted
  // infrastructure". The rack is sized and positioned so no edge touches
  // the cloud outline at any render size.
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <path d="M23.3 25.3H12a9.3 9.3 0 1 1 8.9-12h2.4a6 6 0 1 1 0 12Z" stroke="var(--color-slate-500)" stroke-width="1.5" stroke-linejoin="round" />
    <rect x="11" y="14.4" width="10" height="3.4" rx="1" stroke="var(--color-amber-500)" stroke-width="1.3" />
    <circle cx="18.8" cy="16.1" r="0.7" fill="var(--color-amber-500)" />
    <rect x="11" y="19" width="10" height="3.4" rx="1" stroke="var(--color-amber-500)" stroke-width="1.3" />
    <circle cx="18.8" cy="20.7" r="0.7" fill="var(--color-amber-500)" />
  </svg>
)}

{name === 'gateway' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <rect x="6" y="6" width="20" height="20" rx="2" stroke="var(--color-amber-500)" stroke-width="1.5" />
    <circle cx="16" cy="14" r="2.5" stroke="var(--color-amber-500)" stroke-width="1.5" />
    <line x1="16" y1="16.5" x2="16" y2="20.5" stroke="var(--color-amber-500)" stroke-width="1.5" stroke-linecap="round" />
  </svg>
)}

{name === 'disk-recovery' && (
  // Data recovery: a database cylinder (the data) with a circular restore
  // arrow at the lower right (the recovery). Lucide database-backup
  // geometry scaled to the 32 box — the "undo arrow in a square" it
  // replaces read as a generic undo button, not data recovery.
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <ellipse cx="16" cy="6.67" rx="12" ry="4" stroke="var(--color-slate-500)" stroke-width="1.5" />
    <path d="M4 16a12 4 0 0 0 6.67 3.59" stroke="var(--color-slate-500)" stroke-width="1.5" stroke-linecap="round" />
    <path d="M4 6.67v18.67a12 4 0 0 0 8.63 3.84" stroke="var(--color-slate-500)" stroke-width="1.5" stroke-linecap="round" />
    <path d="M28 12.35V6.67" stroke="var(--color-slate-500)" stroke-width="1.5" stroke-linecap="round" />
    <path d="M16 16v5.33h5.33" stroke="var(--color-amber-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M29.33 16.67a6.67 6.67 0 0 0-12 4" stroke="var(--color-amber-500)" stroke-width="1.5" stroke-linecap="round" />
    <path d="M17.33 26.67a6.67 6.67 0 0 0 12-4" stroke="var(--color-amber-500)" stroke-width="1.5" stroke-linecap="round" />
  </svg>
)}

{name === 'camera' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <rect x="5" y="11" width="18" height="12" rx="2" stroke="var(--color-slate-500)" stroke-width="1.5" />
    <path d="M23 14l4-2v10l-4-2z" stroke="var(--color-slate-500)" stroke-width="1.5" stroke-linejoin="round" />
    <circle cx="14" cy="17" r="3" stroke="var(--color-amber-500)" stroke-width="1.5" />
  </svg>
)}

{name === 'door-access' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <rect x="9" y="4" width="14" height="24" rx="1.5" stroke="var(--color-slate-500)" stroke-width="1.5" />
    <circle cx="19" cy="16" r="1.5" fill="var(--color-amber-500)" />
  </svg>
)}

{name === 'stack' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <rect x="4" y="16" width="12" height="12" rx="2" stroke="var(--color-amber-500)" stroke-width="1.5" />
    <rect x="10" y="10" width="12" height="12" rx="2" stroke="var(--color-amber-500)" stroke-width="1.5" />
    <rect x="16" y="4" width="12" height="12" rx="2" stroke="var(--color-amber-500)" stroke-width="1.5" />
  </svg>
)}

{name === 'dashboard-gauge' && (
  // Monitoring dashboard: a monitor (screen + stand) with a gauge arc and
  // a mini bar chart INSIDE the screen. The previous version hung the bars
  // below the screen frame, which read as legs/drips at large sizes.
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true" class={className}>
    <rect x="4" y="5" width="24" height="16" rx="2" stroke="var(--color-slate-500)" stroke-width="1.5" />
    <path d="M8 16.5a4.5 4.5 0 0 1 8-2.8" stroke="var(--color-amber-500)" stroke-width="1.5" stroke-linecap="round" />
    <circle cx="16" cy="13.7" r="1" fill="var(--color-amber-500)" />
    <line x1="20" y1="16.5" x2="20" y2="13" stroke="var(--color-slate-500)" stroke-width="1.5" stroke-linecap="round" />
    <line x1="23.5" y1="16.5" x2="23.5" y2="10.5" stroke="var(--color-amber-500)" stroke-width="1.5" stroke-linecap="round" />
    <line x1="16" y1="21" x2="16" y2="24.5" stroke="var(--color-slate-500)" stroke-width="1.5" />
    <line x1="11.5" y1="25.5" x2="20.5" y2="25.5" stroke="var(--color-slate-500)" stroke-width="1.5" stroke-linecap="round" />
  </svg>
)}
