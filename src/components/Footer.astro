---
import { site, services, serviceLink } from '~/lib/site';
const year = new Date().getFullYear();

// Technology we deploy & support (replaces the old service-area list).
const partners = ['Cloudflare', 'Ubiquiti UniFi', 'Microsoft 365', 'Datto', 'Entra ID'];
---

<footer class="bg-dot-grid" style="background-color: var(--color-bg-page)">
  <div class="container-wide py-16">
    <div class="grid gap-12 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5 font-display font-semibold text-lg mb-4" style="color: var(--color-text-primary)">
          <img src="/logo.png" alt="AllTech logo" class="h-9 w-auto" width="36" height="36" onerror="this.style.display='none'" />
          AllTech
        </div>
        <p class="text-sm max-w-sm leading-relaxed" style="color: var(--color-text-muted)">
          Managed IT, cybersecurity, and Cloudflare-powered network infrastructure
          for businesses across Northern Utah, the Wasatch Front, and southern Idaho.
        </p>

        <address class="mt-6 not-italic text-sm space-y-1.5" style="color: var(--color-text-muted)">
          <div>{site.address.street}</div>
          <div>{site.address.city}, {site.address.region} {site.address.postalCode}</div>
          <div>
            <a href={`tel:${site.phoneE164}`} class="font-mono hover:text-[var(--color-text-primary)] transition" style="color: var(--color-text-default)">
              {site.phone}
            </a>
          </div>
        </address>
      </div>

      <div>
        <h3 class="font-display text-sm uppercase tracking-wider mb-4" style="color: var(--color-text-primary)">Services</h3>
        <ul class="space-y-2 text-sm">
          {services.map((s) => {
            const { href, external } = serviceLink(s);
            return (
              <li>
                <a
                  href={href}
                  class="transition hover:text-[var(--color-text-primary)]"
                  style="color: var(--color-text-muted)"
                  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {s.name}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <div>
        <h3 class="font-display text-sm uppercase tracking-wider mb-4" style="color: var(--color-text-primary)">Technology</h3>
        <ul class="space-y-2 text-sm">
          {partners.map((p) => (
            <li style="color: var(--color-text-muted)">{p}</li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t flex flex-col sm:flex-row justify-between gap-4 text-xs" style="border-color: var(--color-border-subtle); color: var(--color-text-subtle)">
      <div>© {year} AllTech. All rights reserved.</div>
      <div class="flex gap-5">
        <a href="/privacy" class="hover:text-[var(--color-text-primary)] transition">Privacy</a>
        <a href="/terms" class="hover:text-[var(--color-text-primary)] transition">Terms</a>
        <a href="https://remote.askalltech.com:8040" class="hover:text-[var(--color-text-primary)] transition">Remote Assistance</a>
      </div>
    </div>
  </div>
</footer>
